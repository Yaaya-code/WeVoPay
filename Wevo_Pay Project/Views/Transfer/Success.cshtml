@model Wevo_Pay_Project.Models.TransferRequest

@{
    ViewData["Title"] = "Transfer Created";
}

<div class="row justify-content-center">

    <div class="col-lg-7">

        <div class="card shadow border-0 rounded-4 text-center">

            <div class="card-body p-5">

                <div class="mb-4">

                    <i class="bi bi-check-circle-fill text-success"
                           style="font-size:70px">
                    </i>

                </div>

                <h2 class="fw-bold">
                    Transfer Request Created!
                </h2>

                <p class="text-muted">
                    Your transfer request has been submitted successfully.
                </p>
                <div class="alert alert-warning border-0 rounded-3 text-start mt-3 mb-0">
                    <div class="d-flex gap-2">
                        <i class="bi bi-stopwatch fs-4"></i>
                        <div>
                            <strong>1-hour verification limit</strong>
                            <p class="mb-0 small">
                                An admin must verify this request within <strong>1 hour</strong>.
                                If not, it will be <strong>cancelled automatically</strong>.
                                Send the money to the company wallet as soon as possible.
                            </p>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="text-start mt-4">

                    <div class="d-flex justify-content-between mb-3">

                        <span>
                            Transfer Amount
                        </span>

                        <strong>
                            @Model.TransferAmount.ToString("N2") EGP
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>
                            Fee
                        </span>

                        <strong>
                            @Model.Fee.ToString("N2") EGP
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>
                            Total
                        </span>

                        <strong>
                            @Model.TotalAmount.ToString("N2") EGP
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>
                            Status
                        </span>

                        <span class="badge bg-warning text-dark">
                            @Model.Status
                        </span>

                    </div>

                    <div class="d-flex justify-content-between">

                        <span>
                            Request ID
                        </span>

                        <strong>
                            #@Model.Id
                        </strong>

                    </div>

                </div>

                <div class="mt-5">

                    <a asp-controller="User"
                           asp-action="Dashboard"
                           class="btn btn-primary">

                        Go Dashboard

                    </a>

                    <a asp-controller="Transfer"
                           asp-action="MyTransfers"
                           class="btn btn-outline-secondary ms-2">

                        My Transfers

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>
