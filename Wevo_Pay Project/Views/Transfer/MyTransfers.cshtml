@model List<Wevo_Pay_Project.Models.TransferRequest>

@{
    ViewData["Title"] = "My Transfers";
}

<div class="d-flex justify-content-between align-items-center mb-4">

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="color: #0f172a; font-weight: 700; margin-bottom: 4px;">My Transfers</h2>
        <p style="color: #64748b; margin-bottom: 0;">Track and manage all your transfer requests</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4" 
       style="background-color: #2563eb; border-color: #2563eb;">
        <i class="bi bi-plus-circle me-2"></i> New Transfer
    </a>

</div>

<form method="get" class="card shadow-sm border-0 mb-4">

<form method="get" class="card border-0 shadow-sm mb-4" style="background-color: #ffffff;">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small" style="color: #475569; font-weight: 500;">Search</label>
                <input type="text" class="form-control" name="search" value="@ViewBag.Search"
                       placeholder="Search by wallet or InstaPay address..." 
                       style="border-color: #e2e8f0;">
            </div>

            <div class="col-md-3">
                <label class="form-label small" style="color: #475569; font-weight: 500;">Status</label>
                <select name="status" class="form-select" style="border-color: #e2e8f0;">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<Wevo_Pay_Project.Enums.TransferStatus>())
                    {
                        <option value="@s" selected="@(ViewBag.Status != null && ViewBag.Status.Equals(s))">@s</option>
                        }
                </select>

            </div>
            <div class="col-md-2">
                <button type="submit" class="btn w-100" 
                        style="background-color: #2563eb; color: white; border: none;">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </div>
            <div class="col-md-2">
                <a asp-action="MyTransfers" class="btn w-100" 
                   style="background-color: #f1f5f9; color: #334155; border: 1px solid #e2e8f0;">
                    Reset

                </a>
            </div>
        </div>
    </div>
</form>
<div class="card border-0 shadow-sm" style="background-color: #ffffff;">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: #f8fafc;">
                <tr>
                            <th class="ps-4" style="color: #475569; font-weight: 600;">Wallet</th>
                            <th style="color: #475569; font-weight: 600;">Amount</th>
                            <th style="color: #475569; font-weight: 600;">Fee</th>
                            <th style="color: #475569; font-weight: 600;">Total</th>
                            <th style="color: #475569; font-weight: 600;">Status</th>
                            <th style="color: #475569; font-weight: 600;">Date</th>
                            <th class="text-end pe-4" style="color: #475569; font-weight: 600;">Action</th>
                </tr>
            </thead>
            <tbody>
                    @foreach (var item in Model)
                    {
                            <tr style="border-bottom: 1px solid #f1f5f9;">
                                <td class="ps-4">
                                    <span style="color: #1e293b; font-weight: 600;">@item.CompanyWallet.WalletName</span>
                                </td>
                            <td>
                                    <span style="color: #1e293b; font-weight: 600;">@item.TransferAmount.ToString("N2")</span>
                                    <span style="color: #64748b; font-size: 0.875rem;">EGP</span>
                            </td>
                            <td>
                                    <span style="color: #64748b;">@item.Fee.ToString("N2") EGP</span>
                            </td>
                            <td>
                                    <span style="color: #0f172a; font-weight: 700;">@item.TotalAmount.ToString("N2") EGP</span>
                            </td>
                            <td>

                                @switch (item.Status)
                                {
                                    case Wevo_Pay_Project.Enums.TransferStatus.Pending:
                                            <span class="badge px-3 py-2" style="background-color: #fef3c7; color: #92400e; font-weight: 500;">Pending</span>
                                        break;
                                    case Wevo_Pay_Project.Enums.TransferStatus.Verified:
                                            <span class="badge px-3 py-2" style="background-color: #dbeafe; color: #1e40af; font-weight: 500;">Verified</span>
                                        break;
                                    case Wevo_Pay_Project.Enums.TransferStatus.Completed:
                                            <span class="badge px-3 py-2" style="background-color: #dcfce7; color: #166534; font-weight: 500;">Completed</span>
                                        break;
                                    default:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                }

                            </td>

                            <td>
                                @item.CreatedAt.ToString("dd MMM yyyy")
                            </td>

                            <td>

                                <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">

                                    <i class="bi bi-eye"></i>

                                    Details

                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="7" class="text-center py-5">

                            <i class="bi bi-inbox fs-1 text-muted"></i>

                            <p class="mt-3 text-muted">

                                No transfers found.

                            </p>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.Page == i ? "active" : "")">

                    <a class="page-link"
                           asp-action="MyTransfers"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search"
                           asp-route-status="@ViewBag.Status">

                        @i

                    </a>

                </li>
            }

        </ul>

    </nav>
}