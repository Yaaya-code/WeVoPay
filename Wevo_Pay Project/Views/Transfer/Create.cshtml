@model Wevo_Pay_Project.DTOs.CreateTransferDto

@{
    ViewData["Title"] = "Create Transfer";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-header bg-primary text-white rounded-top-4 p-4">

                <h2 class="mb-1">
                    <i class="bi bi-send"></i>
                    New Transfer
                </h2>

                <p class="mb-0 opacity-75">
                    Create a new transfer request securely.
                </p>

            </div>


            <div class="card-body p-4">


                <form asp-action="Create" method="post">

                    @Html.AntiForgeryToken()


                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All"
                             class="alert alert-danger">
                        </div>
                    }


                    <div class="mb-4">

                        <label class="form-label fw-semibold">
                            Select Wallet
                        </label>


                        <select asp-for="CompanyWalletId"
                                class="form-select form-select-lg">

                            <option value="">
                                -- Choose Wallet --
                            </option>


                            @foreach (var wallet in ViewBag.Wallets)
                            {
                                <option value="@wallet.Id">

                                    @wallet.WalletName
                                    -
                                    @wallet.WalletNumber

                                </option>
                            }

                        </select>


                        <span asp-validation-for="CompanyWalletId"
                              class="text-danger">
                        </span>

                    </div>



                    <div class="mb-4">

                        <label class="form-label fw-semibold">
                            InstaPay Address
                        </label>


                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-person"></i>
                            </span>

                            <input asp-for="InstaPayAddress"
                                   class="form-control form-control-lg"
                                   placeholder="example@instapay" />

                        </div>


                        <span asp-validation-for="InstaPayAddress"
                              class="text-danger">
                        </span>

                    </div>



                    <div class="mb-4">

                        <label class="form-label fw-semibold">
                            Transfer Amount
                        </label>


                        <div class="input-group">

                            <span class="input-group-text">
                                EGP
                            </span>

                            <input asp-for="TransferAmount"
                                   id="amount"
                                   class="form-control form-control-lg"
                                   placeholder="Enter amount" />

                        </div>


                        <span asp-validation-for="TransferAmount"
                              class="text-danger">
                        </span>

                    </div>



                    <div class="card bg-light border-0 mb-4">

                        <div class="card-body">

                            <div class="d-flex justify-content-between mb-2">

                                <span class="text-muted">
                                    Fee
                                </span>

                                <span id="fee">
                                    0 EGP
                                </span>

                            </div>


                            <div class="d-flex justify-content-between fw-bold">

                                <span>
                                    Total
                                </span>

                                <span id="total">
                                    0 EGP
                                </span>

                            </div>

                        </div>

                    </div>



                    <div class="mb-4">

                        <label class="form-label fw-semibold">
                            Notes
                        </label>


                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="3"
                                      placeholder="Optional notes">
                        </textarea>

                        </div>



                        <button type="submit"
                                class="btn btn-primary btn-lg w-100">

                            <i class="bi bi-send-check"></i>

                            Send Transfer Request

                        </button>


                    </form>


                </div>

            </div>

        </div>

    </div>


    @section Scripts {

        <partial name="_ValidationScriptsPartial" />


        <script>

            const amountInput = document.getElementById("amount");

            const feeElement = document.getElementById("fee");

            const totalElement = document.getElementById("total");


            amountInput.addEventListener("input", function () {

                let amount = parseFloat(this.value) || 0;


                let fee = amount * 0.015;

                let total = amount + fee;


                feeElement.innerText =
                    fee.toFixed(2) + " EGP";


                totalElement.innerText =
                    total.toFixed(2) + " EGP";

            });


        </script>
    }