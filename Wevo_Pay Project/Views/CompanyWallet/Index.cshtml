@model List<Wevo_Pay_Project.Models.CompanyWallet>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Wallets";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2 class="fw-bold">
        Company Wallets
    </h2>

    <a asp-action="Create"
           class="btn btn-primary">

        Add New Wallet

    </a>

</div>

<form method="get" asp-action="Index" class="mb-4">

    <div class="row">

        <div class="col-md-6">

            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Search by wallet name or number..." />

        </div>

        <div class="col-md-2">

            <button class="btn btn-primary w-100">

                <i class="bi bi-search"></i>
                Search

            </button>

        </div>

    </div>

</form>

<div class="card shadow-sm border-0 rounded-4">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info">

                No wallets found.

            </div>
        }
        else
        {

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>

                            <th>Name</th>
                            <th>Number</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th width="220">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var wallet in Model)
                        {

                            <tr>

                                <td>
                                    @wallet.WalletName
                                </td>

                                <td>
                                    @wallet.WalletNumber
                                </td>

                                <td>

                                    @if (wallet.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>
                                    @wallet.CreatedAt.ToString("dd/MM/yyyy")
                                </td>

                                <td>

                                    <a asp-action="Edit"
                                           asp-route-id="@wallet.Id"
                                           class="btn btn-warning btn-sm">

                                        Edit

                                    </a>

                                    <form asp-action="ToggleStatus"
                                          method="post"
                                          style="display:inline">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@wallet.Id" />

                                        @if (wallet.IsActive)
                                        {
                                            <button class="btn btn-danger btn-sm">

                                                Disable

                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-success btn-sm">

                                                Enable

                                            </button>
                                        }

                                    </form>

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        }

    </div>

</div>

@if (ViewBag.TotalPages > 1)
{

    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @if (ViewBag.CurrentPage > 1)
            {

                <li class="page-item">

                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-search="@ViewBag.Search">

                        Previous

                    </a>

                </li>

            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {

                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@ViewBag.Search">

                        @i

                    </a>

                </li>

            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {

                <li class="page-item">

                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-search="@ViewBag.Search">

                        Next

                    </a>

                </li>

            }

        </ul>

    </nav>

}
