<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

</head>

<body>

    <div class="container-fluid">

        <div class="row">

            <div class="col-2 bg-dark text-white vh-100">

                <h3 class="mt-3">Admin Panel</h3>

                <hr />

                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link text-white"
                               asp-controller="Admin"
                               asp-action="Dashboard">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                               asp-controller="CompanyWallet"
                               asp-action="Index">
                            Wallets
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                               asp-controller="CompanyWallet"
                               asp-action="Create">
                            Add Wallet
                        </a>
                    </li>

                    <li class="nav-item">

                        <a class="nav-link text-white"
                               asp-controller="Admin"
                               asp-action="PendingTransfers">

                            <i class="bi bi-hourglass-split"></i>
                            Pending Transfers

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link text-white"
                               asp-controller="Admin"
                               asp-action="VerifiedTransfers">

                            <i class="bi bi-check-circle"></i>
                            Verified Transfers

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link text-white"
                               asp-controller="Admin"
                               asp-action="CompletedTransfers">

                            <i class="bi bi-check2-all"></i>
                            Completed Transfers

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link text-white"
                               asp-controller="Admin"
                               asp-action="RejectedTransfers">

                            <i class="bi bi-x-circle"></i>
                            Rejected Transfers

                        </a>

                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                               asp-controller="SystemSetting"
                               asp-action="Index">
                            System Settings
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Message"
                           asp-action="AdminIndex">
                            Message Center
                        </a>
                    </li>

                    <li class="nav-item mt-4">
                        <form asp-controller="Account"
                              asp-action="Logout"
                              method="post">

                            @Html.AntiForgeryToken()

                            <button class="btn btn-danger w-100">
                                Logout
                            </button>

                        </form>
                    </li>

                </ul>

            </div>

            <div class="col-10 p-4">

                @RenderBody()

            </div>

        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
