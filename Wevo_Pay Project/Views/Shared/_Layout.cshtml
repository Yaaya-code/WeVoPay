<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WevoPay</title>

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Project CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/wevopay.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Wevo_Pay_Project.styles.css" asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top">
        <div class="container">

            <a class="navbar-brand fw-bold fs-3 text-primary"
                   asp-controller="Home"
                   asp-action="Index">

                <i class="bi bi-wallet2"></i>
                WevoPay

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMenu">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarMenu">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav mx-auto">

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i>
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="CompanyWallet"
                                       asp-action="Index">
                                    <i class="bi bi-wallet"></i>
                                    Wallets
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Transaction"
                                       asp-action="Index">
                                    <i class="bi bi-arrow-left-right"></i>
                                    Transactions
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="Settings">
                                    <i class="bi bi-gear"></i>
                                    Settings
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="User"
                                       asp-action="Dashboard">
                                    <i class="bi bi-house-door"></i>
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Transfer"
                                       asp-action="Create">
                                    <i class="bi bi-plus-circle"></i>
                                    New Transfer
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Transfer"
                                       asp-action="MyTransfers">
                                    <i class="bi bi-clock-history"></i>
                                    My Transfers
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                <i class="bi bi-person-circle fs-5"></i>
                                @User.Identity.Name

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow">

                                <li>
                                    <h6 class="dropdown-header">
                                        Welcome 👋
                                    </h6>
                                </li>

                                <li>
                                    <span class="dropdown-item-text">
                                        @User.Identity.Name
                                    </span>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>

                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button class="dropdown-item text-danger">

                                            <i class="bi bi-box-arrow-right"></i>
                                            Logout

                                        </button>

                                    </form>

                                </li>

                            </ul>

                        </li>

                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-primary ms-2 px-4"
                                   asp-controller="Account"
                                   asp-action="Register">
                                Get Started
                            </a>
                        </li>

                    </ul>
                }

            </div>

        </div>
    </nav>

    <main class="container py-5">

        @RenderBody()

    </main>

    <footer class="bg-white border-top mt-5">

        <div class="container py-4 text-center text-muted">

            © @DateTime.Now.Year WevoPay. All rights reserved.

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>