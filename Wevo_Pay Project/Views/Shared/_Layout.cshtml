<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WevoPay</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Wevo_Pay_Project.styles.css" asp-append-version="true" />
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold fs-4"
                   asp-controller="User"
                   asp-action="Dashboard">
                <i class="bi bi-wallet2"></i> WevoPay
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbar">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbar">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="User"
                                   asp-action="Dashboard">
                                <i class="bi bi-house-door"></i>
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="Transfer"
                                   asp-action="Create">
                                <i class="bi bi-plus-circle"></i>
                                New Transfer
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="Transfer"
                                   asp-action="MyTransfers">
                                <i class="bi bi-clock-history"></i>
                                My Transfers
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i>
                                    Admin Dashboard
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                <i class="bi bi-person-circle"></i>
                                @User.Identity.Name

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <span class="dropdown-item-text fw-bold">
                                        @User.Identity.Name
                                    </span>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>

                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button class="dropdown-item text-danger">

                                            <i class="bi bi-box-arrow-right"></i>
                                            Logout

                                        </button>

                                    </form>

                                </li>

                            </ul>

                        </li>

                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-light ms-2"
                                   asp-controller="Account"
                                   asp-action="Register">
                                Register
                            </a>
                        </li>

                    </ul>
                }

            </div>

        </div>
    </nav>

    <div class="container py-4">

        @RenderBody()

    </div>

    <footer class="border-top bg-white mt-5">

        <div class="container py-3 text-center text-muted">

            © @DateTime.Now.Year WevoPay

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>