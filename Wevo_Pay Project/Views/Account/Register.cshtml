@model Wevo_Pay_Project.DTOs.RegisterDto

@{
    ViewData["Title"] = "Register";
    ViewData["FullWidth"] = true;
}

<div class="auth-page">
    <div class="auth-bg" aria-hidden="true">
        <span class="auth-shape auth-shape-circle auth-shape-1"></span>
        <span class="auth-shape auth-shape-circle auth-shape-2"></span>
        <span class="auth-shape auth-shape-circle auth-shape-3"></span>
        <span class="auth-shape auth-shape-ring auth-shape-4"></span>
        <span class="auth-shape auth-shape-ring auth-shape-5"></span>
        <span class="auth-shape auth-shape-blob auth-shape-6"></span>
        <span class="auth-shape auth-shape-blob auth-shape-7"></span>
        <span class="auth-shape auth-shape-square auth-shape-8"></span>
        <span class="auth-shape auth-shape-square auth-shape-9"></span>
        <div class="auth-grid"></div>
        <div class="auth-dots"></div>
    </div>

    <div class="auth-page-inner">

        <div class="auth-card auth-card-wide auth-card-register wevo-card">
            <div class="auth-side">
                <div class="auth-side-content">
                    <div class="auth-side-badge">
                        <i class="bi bi-wallet2"></i>
                        Wevo Pay
                    </div>
                    <h2 class="auth-side-title">The bridge between wallets &amp; InstaPay</h2>
                    <p class="auth-side-text">
                        Egyptian wallets like Vodafone Cash can't send to InstaPay directly.
                        Wevo Pay fixes that - create an account and transfer money between them safely.
                    </p>
                    <ul class="auth-features">
                        <li>
                            <span class="auth-feature-icon"><i class="bi bi-phone"></i></span>
                            Vodafone Cash &amp; local wallets
                        </li>
                        <li>
                            <span class="auth-feature-icon"><i class="bi bi-bank"></i></span>
                            Reach InstaPay without the hassle
                        </li>
                        <li>
                            <span class="auth-feature-icon"><i class="bi bi-shield-check"></i></span>
                            Secure escrow-style P2P transfers
                        </li>
                    </ul>
                </div>
            </div>
            <div class="auth-main">
                <div class="auth-header">
                    <div class="auth-icon">
                        <i class="bi bi-person-plus"></i>
                    </div>
                    <h1 class="auth-title">Create account</h1>
                    <p class="auth-subtitle">Fill in your details to get started</p>
                </div>

                <form asp-action="Register" method="post" class="auth-form" id="registerForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger auth-alert" role="alert"></div>

                    <div class="auth-form-grid">
                        <div class="auth-field mb-3">
                            <label asp-for="FullName" class="form-label">Full Name</label>
                            <div class="input-icon-group">
                                <i class="bi bi-person-badge input-icon"></i>
                                <input asp-for="FullName"
                                       class="form-control form-control-lg auth-input"
                                       placeholder="Your full name"
                                       autocomplete="name" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="auth-field mb-3">
                            <label asp-for="UserName" class="form-label">Username</label>
                            <div class="input-icon-group">
                                <i class="bi bi-at input-icon"></i>
                                <input asp-for="UserName"
                                       class="form-control form-control-lg auth-input"
                                       placeholder="Choose a username"
                                       autocomplete="username" />
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="auth-field mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <div class="input-icon-group">
                                <i class="bi bi-envelope input-icon"></i>
                                <input asp-for="Email"
                                       type="email"
                                       class="form-control form-control-lg auth-input"
                                       placeholder="you@example.com"
                                       autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="auth-field mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                            <div class="input-icon-group">
                                <i class="bi bi-telephone input-icon"></i>
                                <input asp-for="PhoneNumber"
                                       type="tel"
                                       class="form-control form-control-lg auth-input"
                                       placeholder="Your phone number"
                                       autocomplete="tel" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="auth-field mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <div class="input-icon-group">
                                <i class="bi bi-lock input-icon"></i>
                                <input asp-for="Password"
                                       type="password"
                                       class="form-control form-control-lg auth-input auth-input-password"
                                       id="passwordInput"
                                       placeholder="Min. 6 characters"
                                       autocomplete="new-password" />
                                <button type="button"
                                        class="auth-toggle-password"
                                        id="togglePassword"
                                        aria-label="Show password"
                                        title="Show password">
                                    <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="auth-field mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <div class="input-icon-group">
                                <i class="bi bi-shield-lock input-icon"></i>
                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       class="form-control form-control-lg auth-input auth-input-password"
                                       id="confirmPasswordInput"
                                       placeholder="Repeat your password"
                                       autocomplete="new-password" />
                                <button type="button"
                                        class="auth-toggle-password"
                                        id="toggleConfirmPassword"
                                        aria-label="Show password"
                                        title="Show password">
                                    <i class="bi bi-eye" id="toggleConfirmPasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="auth-referral mb-4">
                        <div class="form-check auth-referral-check">
                            <input asp-for="WasReferred"
                                   class="form-check-input"
                                   type="checkbox"
                                   id="wasReferredCheck" />
                            <label class="form-check-label" for="wasReferredCheck">
                                I was referred by someone
                            </label>
                        </div>

                        <div id="referralFields"
                             class="auth-referral-fields mt-3 @(Model.WasReferred ? "" : "d-none")">
                            <label asp-for="ReferralCode" class="form-label">
                                Referral link or username
                                <span class="text-danger">*</span>
                            </label>
                            <p class="create-hint mb-2">
                                Paste the full link (e.g. .../ref/username) or just the username.
                            </p>
                            <div class="input-icon-group">
                                <i class="bi bi-link-45deg input-icon"></i>
                                <input asp-for="ReferralCode"
                                       class="form-control form-control-lg auth-input"
                                       id="referralCodeInput"
                                       placeholder="https://.../ref/username or username"
                                       autocomplete="off" />
                            </div>
                            <span asp-validation-for="ReferralCode" class="text-danger small"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 auth-submit mt-2" id="registerSubmit">
                        <span class="auth-submit-label">
                            <i class="bi bi-person-check me-1"></i>
                            Create Account
                        </span>
                        <span class="auth-submit-loading d-none">
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            Creating account...
                        </span>
                    </button>
                </form>

                <div class="auth-footer">
                    <p class="mb-0">
                        Already have an account?
                        <a asp-controller="Account" asp-action="Login" class="auth-link">
                            Sign in
                        </a>
                    </p>
                </div>
            </div>

        </div>

        <p class="auth-trust text-center">
            <i class="bi bi-lock-fill"></i>
            Secure encrypted connection
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const page = document.querySelector('.auth-page');
            const shapes = document.querySelectorAll('.auth-shape');
            const form = document.getElementById('registerForm');
            const submitBtn = document.getElementById('registerSubmit');

            function setupPasswordToggle(buttonId, inputId, iconId) {
                const toggleBtn = document.getElementById(buttonId);
                const passwordInput = document.getElementById(inputId);
                const toggleIcon = document.getElementById(iconId);

                if (!toggleBtn || !passwordInput || !toggleIcon) return;

                toggleBtn.addEventListener('click', function () {
                    const isHidden = passwordInput.type === 'password';
                    passwordInput.type = isHidden ? 'text' : 'password';
                    toggleIcon.classList.toggle('bi-eye', !isHidden);
                    toggleIcon.classList.toggle('bi-eye-slash', isHidden);
                    toggleBtn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
                    toggleBtn.setAttribute('title', isHidden ? 'Hide password' : 'Show password');
                });
            }

            setupPasswordToggle('togglePassword', 'passwordInput', 'togglePasswordIcon');
            setupPasswordToggle('toggleConfirmPassword', 'confirmPasswordInput', 'toggleConfirmPasswordIcon');

            const referredCheck = document.getElementById('wasReferredCheck');
            const referralFields = document.getElementById('referralFields');
            const referralInput = document.getElementById('referralCodeInput');

            function syncReferralFields() {
                if (!referredCheck || !referralFields) return;
                if (referredCheck.checked) {
                    referralFields.classList.remove('d-none');
                    if (referralInput) referralInput.required = true;
                } else {
                    referralFields.classList.add('d-none');
                    if (referralInput) {
                        referralInput.required = false;
                        referralInput.value = '';
                    }
                }
            }

            referredCheck?.addEventListener('change', syncReferralFields);
            syncReferralFields();

            document.querySelectorAll('.input-icon-group .auth-input').forEach(function (input) {
                input.addEventListener('focus', function () {
                    input.closest('.input-icon-group')?.classList.add('is-focused');
                });
                input.addEventListener('blur', function () {
                    input.closest('.input-icon-group')?.classList.remove('is-focused');
                });
            });

            if (form && submitBtn) {
                form.addEventListener('submit', function () {
                    if (!form.checkValidity || form.checkValidity()) {
                        submitBtn.classList.add('is-loading');
                        submitBtn.disabled = true;
                        const label = submitBtn.querySelector('.auth-submit-label');
                        const loading = submitBtn.querySelector('.auth-submit-loading');
                        if (label) label.classList.add('d-none');
                        if (loading) loading.classList.remove('d-none');
                    }
                });
            }

            if (page && shapes.length) {
                page.addEventListener('mousemove', function (e) {
                    const rect = page.getBoundingClientRect();
                    const x = (e.clientX - rect.left) / rect.width - 0.5;
                    const y = (e.clientY - rect.top) / rect.height - 0.5;

                    shapes.forEach(function (shape, index) {
                        const depth = (index % 4 + 1) * 6;
                        shape.style.translate = (x * depth) + 'px ' + (y * depth) + 'px';
                    });
                });
            }
        })();
    </script>
}
