@model List<Wevo_Pay_Project.Models.TransferRequest>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending Transfers";
}

<h2>Pending Transfers</h2>


<table class="table">

    <thead>
        <tr>
            <th>User</th>
            <th>Wallet</th>
            <th>Amount</th>
            <th>Fee</th>
            <th>Total</th>
            <th>InstaPay</th>
            <th>Actions</th>
        </tr>
    </thead>


    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @item.User.FullName
                </td>


                <td>
                    @item.CompanyWallet.WalletName
                </td>


                <td>
                    @item.TransferAmount
                </td>


                <td>
                    @item.Fee
                </td>


                <td>
                    @item.TotalAmount
                </td>


                <td>
                    @item.InstaPayAddress
                </td>


                <td>

                    <form asp-action="Verify"
                          method="post"
                          style="display:inline">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@item.Id" />

                        <button class="btn btn-warning">
                            Verify
                        </button>

                    </form>


                    <form asp-action="Reject"
                          method="post"
                          style="display:inline">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@item.Id" />

                        <button class="btn btn-danger">
                            Reject
                        </button>

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>