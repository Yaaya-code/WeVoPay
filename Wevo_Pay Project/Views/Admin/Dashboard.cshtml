@model Wevo_Pay_Project.DTOs.AdminDashboardDto

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">
            Admin Dashboard
        </h2>

        <p class="text-muted">
            Overview of WevoPay system activity.
        </p>
    </div>

</div>

<div class="row g-4">

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Total Users
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.TotalUsers
                        </h2>

                    </div>

                    <i class="bi bi-people fs-1 text-primary"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Total Wallets
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.TotalWallets
                        </h2>

                    </div>

                    <i class="bi bi-wallet2 fs-1 text-success"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Pending Transfers
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.PendingTransfers
                        </h2>

                    </div>

                    <i class="bi bi-clock-history fs-1 text-warning"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Verified Transfers
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.VerifiedTransfers
                        </h2>

                    </div>

                    <i class="bi bi-patch-check fs-1 text-info"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Completed Transfers
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.CompletedTransfers
                        </h2>

                    </div>

                    <i class="bi bi-check-circle fs-1 text-success"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-4">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h6 class="text-muted">
                            Rejected Transfers
                        </h6>

                        <h2 class="fw-bold mb-0">
                            @Model.RejectedTransfers
                        </h2>

                    </div>

                    <i class="bi bi-x-circle fs-1 text-danger"></i>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="row g-4 mt-2">

    <div class="col-md-6">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <h6 class="text-muted">
                    Total Revenue
                </h6>

                <h2 class="fw-bold">
                    @Model.TotalRevenue.ToString("N2") EGP
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-body">

                <h6 class="text-muted">
                    Today's Revenue
                </h6>

                <h2 class="fw-bold">
                    @Model.TodayRevenue.ToString("N2") EGP
                </h2>

            </div>

        </div>

    </div>

</div>
